# AGENT_HULK_NAME=Hulk
# AGENT_HULK_BOT_TOKEN=xoxb-...
# AGENT_HULK_APP_TOKEN=xapp-...
# AGENT_HULK_SOUL=./agents/hulk/SOUL.md

