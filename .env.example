# ============================================================
# Multi-Agent Slack Bot — Environment Variables
# ============================================================
# cp .env.example .env and replace with actual tokens

# Claude API — choose one auth method (used by claude-agent-sdk)
# Method 1: API Key
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
# Method 2: OAuth Token
# CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token-here

CLAUDE_MODEL=claude-sonnet-4-20250514
MAX_TOKENS=4096

# Loop Prevention
MAX_CHAIN_DEPTH=10        # Max bot responses per thread
COOLDOWN_SECONDS=2.0      # Delay between consecutive responses (seconds)

# SOUL.md directory
AGENTS_DIR=./agents

# ============================================================
# Agent: FRIDAY (PO)
# ============================================================
AGENT_FRIDAY_NAME=FRIDAY
AGENT_FRIDAY_BOT_TOKEN=xoxb-your-friday-bot-token
AGENT_FRIDAY_APP_TOKEN=xapp-your-friday-app-token
AGENT_FRIDAY_SOUL=./agents/friday/SOUL.md

# ============================================================
# Agent: BLACK_WIDOW (Designer)
# ============================================================
AGENT_BLACK_WIDOW_NAME=Black Widow
AGENT_BLACK_WIDOW_BOT_TOKEN=xoxb-your-black-widow-bot-token
AGENT_BLACK_WIDOW_APP_TOKEN=xapp-your-black-widow-app-token
AGENT_BLACK_WIDOW_SOUL=./agents/black-widow/SOUL.md

# ============================================================
# Agent: SPIDER_MAN (Frontend)
# ============================================================
# AGENT_SPIDER_MAN_NAME=Spider-Man
# AGENT_SPIDER_MAN_BOT_TOKEN=xoxb-...
# AGENT_SPIDER_MAN_APP_TOKEN=xapp-...
# AGENT_SPIDER_MAN_SOUL=./agents/spider-man/SOUL.md

# ============================================================
# Agent: HULK (Backend)
